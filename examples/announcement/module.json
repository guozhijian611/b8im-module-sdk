{
  "$schema": "../../schema/module.schema.json",
  "module_key": "announcement",
  "name": "公告",
  "version": "0.1.0",
  "description": "B8IM 平台公告和租户公告的内置基础能力。",
  "category": "operations",
  "module_type": "foundation",
  "is_builtin": true,
  "license_required": false,
  "min_system_version": "0.1.0",
  "depends_on": [],
  "conflicts_with": [],
  "platforms": [
    "server",
    "admin",
    "tenant",
    "web"
  ],
  "permissions": [
    {
      "slug": "saimulti:admin:announcement:index",
      "name": "平台公告列表",
      "scope": "system",
      "description": "查看平台公告。"
    },
    {
      "slug": "saimulti:admin:announcement:save",
      "name": "发布平台公告",
      "scope": "system",
      "description": "创建和发布平台公告。"
    },
    {
      "slug": "saimulti:admin:announcement:read",
      "name": "平台公告详情",
      "scope": "system",
      "description": "查看单条平台公告。"
    },
    {
      "slug": "saimulti:admin:announcement:update",
      "name": "更新平台公告",
      "scope": "system",
      "description": "编辑、上线或下线平台公告。"
    },
    {
      "slug": "saimulti:admin:announcement:destroy",
      "name": "删除平台公告",
      "scope": "system",
      "description": "删除平台公告。"
    },
    {
      "slug": "saimulti:tenant:announcement:index",
      "name": "租户公告列表",
      "scope": "tenant",
      "description": "查看当前 organization 的公告。"
    },
    {
      "slug": "saimulti:tenant:announcement:save",
      "name": "发布租户公告",
      "scope": "tenant",
      "description": "为当前 organization 创建和发布公告。"
    },
    {
      "slug": "saimulti:tenant:announcement:read",
      "name": "租户公告详情",
      "scope": "tenant",
      "description": "查看当前 organization 的单条公告。"
    },
    {
      "slug": "saimulti:tenant:announcement:update",
      "name": "更新租户公告",
      "scope": "tenant",
      "description": "编辑、上线或下线当前 organization 的公告。"
    },
    {
      "slug": "saimulti:tenant:announcement:destroy",
      "name": "删除租户公告",
      "scope": "tenant",
      "description": "删除当前 organization 的公告。"
    },
    {
      "slug": "saimulti:web:announcement:index",
      "name": "用户端查看公告",
      "scope": "tenant",
      "description": "在当前 organization 的用户端查看有效公告。"
    }
  ],
  "menus": [
    {
      "id": "announcement.admin",
      "name": "平台公告",
      "platform": "admin",
      "type": "menu",
      "parent": "system",
      "route": "/announcement",
      "permission": "saimulti:admin:announcement:index",
      "icon": "ri:notification-3-line",
      "sort": 200
    },
    {
      "id": "announcement.admin.save",
      "name": "发布平台公告",
      "platform": "admin",
      "type": "button",
      "parent": "announcement.admin",
      "permission": "saimulti:admin:announcement:save",
      "sort": 201
    },
    {
      "id": "announcement.admin.read",
      "name": "查看平台公告",
      "platform": "admin",
      "type": "button",
      "parent": "announcement.admin",
      "permission": "saimulti:admin:announcement:read",
      "sort": 202
    },
    {
      "id": "announcement.admin.update",
      "name": "更新平台公告",
      "platform": "admin",
      "type": "button",
      "parent": "announcement.admin",
      "permission": "saimulti:admin:announcement:update",
      "sort": 203
    },
    {
      "id": "announcement.admin.destroy",
      "name": "删除平台公告",
      "platform": "admin",
      "type": "button",
      "parent": "announcement.admin",
      "permission": "saimulti:admin:announcement:destroy",
      "sort": 204
    },
    {
      "id": "announcement.tenant",
      "name": "公告管理",
      "platform": "tenant",
      "type": "menu",
      "parent": "operation",
      "route": "/announcement",
      "permission": "saimulti:tenant:announcement:index",
      "icon": "ri:notification-3-line",
      "sort": 200
    },
    {
      "id": "announcement.tenant.save",
      "name": "发布租户公告",
      "platform": "tenant",
      "type": "button",
      "parent": "announcement.tenant",
      "permission": "saimulti:tenant:announcement:save",
      "sort": 201
    },
    {
      "id": "announcement.tenant.read",
      "name": "查看租户公告",
      "platform": "tenant",
      "type": "button",
      "parent": "announcement.tenant",
      "permission": "saimulti:tenant:announcement:read",
      "sort": 202
    },
    {
      "id": "announcement.tenant.update",
      "name": "更新租户公告",
      "platform": "tenant",
      "type": "button",
      "parent": "announcement.tenant",
      "permission": "saimulti:tenant:announcement:update",
      "sort": 203
    },
    {
      "id": "announcement.tenant.destroy",
      "name": "删除租户公告",
      "platform": "tenant",
      "type": "button",
      "parent": "announcement.tenant",
      "permission": "saimulti:tenant:announcement:destroy",
      "sort": 204
    },
    {
      "id": "announcement.web",
      "name": "公告",
      "platform": "web",
      "type": "menu",
      "parent": null,
      "route": "/announcements",
      "permission": "saimulti:web:announcement:index",
      "icon": "ri:notification-3-line",
      "sort": 200
    }
  ],
  "routes": [
    {
      "id": "announcement.admin.page",
      "name": "平台公告页面",
      "platform": "admin",
      "path": "/announcement",
      "component": "@/views/announcement/index.vue",
      "permission": "saimulti:admin:announcement:index"
    },
    {
      "id": "announcement.tenant.page",
      "name": "租户公告页面",
      "platform": "tenant",
      "path": "/announcement",
      "component": "@/views/announcement/index.vue",
      "permission": "saimulti:tenant:announcement:index"
    },
    {
      "id": "announcement.web.page",
      "name": "用户端公告页面",
      "platform": "web",
      "path": "/announcements",
      "component": "@/views/announcement/index.vue",
      "permission": "saimulti:web:announcement:index"
    },
    {
      "id": "announcement.server.admin-list",
      "name": "平台公告列表接口",
      "platform": "server",
      "path": "/saimulti/admin/announcement/index",
      "methods": ["GET"],
      "permission": "saimulti:admin:announcement:index",
      "capability": "announcement.admin.manage"
    },
    {
      "id": "announcement.server.admin-read",
      "name": "平台公告详情接口",
      "platform": "server",
      "path": "/saimulti/admin/announcement/read",
      "methods": ["GET"],
      "permission": "saimulti:admin:announcement:read",
      "capability": "announcement.admin.manage"
    },
    {
      "id": "announcement.server.admin-save",
      "name": "发布平台公告接口",
      "platform": "server",
      "path": "/saimulti/admin/announcement/save",
      "methods": ["POST"],
      "permission": "saimulti:admin:announcement:save",
      "capability": "announcement.admin.manage"
    },
    {
      "id": "announcement.server.admin-update",
      "name": "更新平台公告接口",
      "platform": "server",
      "path": "/saimulti/admin/announcement/update",
      "methods": ["PUT"],
      "permission": "saimulti:admin:announcement:update",
      "capability": "announcement.admin.manage"
    },
    {
      "id": "announcement.server.admin-destroy",
      "name": "删除平台公告接口",
      "platform": "server",
      "path": "/saimulti/admin/announcement/destroy",
      "methods": ["DELETE"],
      "permission": "saimulti:admin:announcement:destroy",
      "capability": "announcement.admin.manage"
    },
    {
      "id": "announcement.server.tenant-list",
      "name": "租户公告列表接口",
      "platform": "server",
      "path": "/saimulti/tenant/announcement/index",
      "methods": ["GET"],
      "permission": "saimulti:tenant:announcement:index",
      "capability": "announcement.tenant.manage"
    },
    {
      "id": "announcement.server.tenant-read",
      "name": "租户公告详情接口",
      "platform": "server",
      "path": "/saimulti/tenant/announcement/read",
      "methods": ["GET"],
      "permission": "saimulti:tenant:announcement:read",
      "capability": "announcement.tenant.manage"
    },
    {
      "id": "announcement.server.tenant-save",
      "name": "发布租户公告接口",
      "platform": "server",
      "path": "/saimulti/tenant/announcement/save",
      "methods": ["POST"],
      "permission": "saimulti:tenant:announcement:save",
      "capability": "announcement.tenant.manage"
    },
    {
      "id": "announcement.server.tenant-update",
      "name": "更新租户公告接口",
      "platform": "server",
      "path": "/saimulti/tenant/announcement/update",
      "methods": ["PUT"],
      "permission": "saimulti:tenant:announcement:update",
      "capability": "announcement.tenant.manage"
    },
    {
      "id": "announcement.server.tenant-destroy",
      "name": "删除租户公告接口",
      "platform": "server",
      "path": "/saimulti/tenant/announcement/destroy",
      "methods": ["DELETE"],
      "permission": "saimulti:tenant:announcement:destroy",
      "capability": "announcement.tenant.manage"
    },
    {
      "id": "announcement.server.web-list",
      "name": "用户端有效公告接口",
      "platform": "server",
      "path": "/saimulti/web/announcement/index",
      "methods": ["GET"],
      "permission": "saimulti:web:announcement:index",
      "capability": "announcement.web.read"
    },
    {
      "id": "announcement.server.web-read",
      "name": "用户端公告详情接口",
      "platform": "server",
      "path": "/saimulti/web/announcement/read",
      "methods": ["GET"],
      "permission": "saimulti:web:announcement:index",
      "capability": "announcement.web.read"
    },
    {
      "id": "announcement.server.web-acknowledge",
      "name": "用户端公告已读确认接口",
      "platform": "server",
      "path": "/saimulti/web/announcement/acknowledge",
      "methods": ["POST"],
      "permission": "saimulti:web:announcement:index",
      "capability": "announcement.web.read"
    }
  ],
  "config": [
    {
      "key": "display_mode",
      "name": "展示方式",
      "description": "租户用户端的默认公告展示方式。",
      "type": "select",
      "scope": "tenant",
      "required": true,
      "sensitive": false,
      "default": "list",
      "options": [
        {"label": "列表", "value": "list"},
        {"label": "弹窗", "value": "popup"},
        {"label": "列表和弹窗", "value": "both"}
      ]
    },
    {
      "key": "require_read_ack",
      "name": "要求已读确认",
      "description": "用户查看后是否记录简单已读确认。",
      "type": "boolean",
      "scope": "tenant",
      "required": true,
      "sensitive": false,
      "default": false
    }
  ],
  "migrations": [
    {
      "id": "20260710010100_create_announcement_tables",
      "version": "0.1.0",
      "platform": "server",
      "path": "server/database/migrations/20260710010100_create_announcement_tables.php",
      "connection": "default",
      "description": "创建公告和已读确认表；租户数据以 organization 隔离。",
      "destructive": false
    }
  ],
  "capabilities": {
    "server": [
      "announcement.admin.manage",
      "announcement.tenant.manage",
      "announcement.web.read"
    ],
    "admin": ["announcement.admin.page"],
    "tenant": ["announcement.tenant.page"],
    "web": ["announcement.web.page", "announcement.web.popup"]
  },
  "hooks": {
    "install": {
      "handler": "B8im\\ModuleSdk\\Example\\Announcement\\Lifecycle::install",
      "scope": "system",
      "transactional": true
    },
    "upgrade": {
      "handler": "B8im\\ModuleSdk\\Example\\Announcement\\Lifecycle::upgrade",
      "scope": "system",
      "transactional": true
    },
    "enable": {
      "handler": "B8im\\ModuleSdk\\Example\\Announcement\\Lifecycle::enable",
      "scope": "both",
      "transactional": true
    },
    "disable": {
      "handler": "B8im\\ModuleSdk\\Example\\Announcement\\Lifecycle::disable",
      "scope": "both",
      "transactional": true
    },
    "uninstall": {
      "handler": "B8im\\ModuleSdk\\Example\\Announcement\\Lifecycle::uninstall",
      "scope": "system",
      "transactional": true
    }
  }
}
