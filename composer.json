{
    "name": "b8im/module-sdk",
    "description": "B8IM module manifest, lifecycle and state contracts",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "composer/semver": "^3.4",
        "opis/json-schema": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "B8im\\ModuleSdk\\": "src/",
            "B8im\\ModuleSdk\\Example\\Announcement\\": "examples/announcement/src/"
        }
    },
    "scripts": {
        "test": "php tests/run.php",
        "lint": "find src tests examples -name '*.php' -print0 | xargs -0 -n1 php -l"
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
